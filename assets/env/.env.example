# Questioare ERA — environment template (safe to commit)
# Copy this file to `.env` in the SAME folder and fill real values.
# See docs/ENV_SETUP.md for which keys go where.

# -----------------------------------------------------------------------------
# FLUTTER / SUPABASE CLIENT (this app)
# Get these from: Supabase Dashboard → Project Settings → API
#   - Project URL  → SUPABASE_URL (looks like https://YOUR_PROJECT_REF.supabase.co)
#   - anon public  → SUPABASE_ANON_KEY (starts with eyJ...)
# -----------------------------------------------------------------------------
# DEMO_MODE=true  → skip Supabase; use offline demo (name/username → home). Keys stay for later.
# DEMO_MODE=false →# Supabase config (if still used for DB/Functions)
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Set to true to bypass auth/backend and just test UI locally
DEMO_MODE=true

# =========================================================
# ELIXPO AUTHENTICATION CONFIG
# Get these from your Elixpo Dashboard > OAuth Apps
# =========================================================
ELIXPO_CLIENT_ID=your_elixpo_client_id
# Provide the Client Secret ONLY if you're executing code-exchange server-side, 
# or if it's explicitly required by Elixpo for PKCEless client apps.
ELIXPO_CLIENT_SECRET=your_elixpo_client_secret

ELIXPO_REDIRECT_URI=questioare://login-callback
ELIXPO_AUTHORIZATION_URL=https://accounts.elixpo.com/oauth/authorize
ELIXPO_TOKEN_URL=https://accounts.elixpo.com/oauth/token
ELIXPO_USERINFO_URL=https://accounts.elixpo.com/api/user
# -----------------------------------------------------------------------------
# NEVER put these in the Flutter app — backend / SQL tools / Prisma only
# From: Dashboard → Connect → Connection string → Session pooler → URI
# Replace [YOUR-PASSWORD] with the database password (Settings → Database)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Optional: service_role key — SERVER ONLY, never ship in mobile/web client
# SUPABASE_SERVICE_ROLE_KEY=
